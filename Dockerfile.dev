FROM python:3.12-slim-bookworm

WORKDIR /usr/src/app

ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1
ENV DEBIAN_FRONTEND noninteractive

# Install GTK3 (needed for WeasyPrint) + ODBC Driver 18 (needed for SQL Server)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgtk-3-0 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libgdk-pixbuf-xlib-2.0-0 \
    libffi-dev \
    shared-mime-info \
    curl \
    gnupg \
    unixodbc-dev \
  && curl https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft-prod.gpg \
  && curl https://packages.microsoft.com/config/debian/12/prod.list > /etc/apt/sources.list.d/mssql-release.list \
  && apt-get update \
  && ACCEPT_EULA=Y apt-get install -y --no-install-recommends msodbcsql18 \
  && rm -rf /var/lib/apt/lists/*

# Install dependencies
RUN pip install --upgrade pip
COPY ./app/requirements.dev.txt .
RUN pip install -r requirements.dev.txt

# Create non-root user
RUN useradd --user-group --system --create-home --no-log-init app

# Copy project
COPY ./app .
COPY .env.dev /usr/src/app/ips_generator/.env

# Pre-create media subdirectories
RUN mkdir -p /usr/src/app/media/returns \
    && mkdir -p /usr/src/app/media/fact_sheets \
    && mkdir -p /usr/src/app/media/site_documents
RUN chown app /usr/src/app/ -R

RUN sed -i 's/\r//' /usr/src/app/start.sh && chmod +x /usr/src/app/start.sh

ENTRYPOINT ["/bin/sh", "-c", "chown -R app:app /usr/src/app/media && su app -s /bin/sh -c /usr/src/app/start.sh"]
